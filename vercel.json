{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/assets/hero-mapa-da-suspeita.webp", "destination": "/assets/hero-emocional.svg" },
    { "source": "/obrigado", "destination": "/obrigado.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}